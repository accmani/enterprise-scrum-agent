# ── Azure OpenAI (preferred) ──────────────────────────────────────────────────
# Leave AZURE_OPENAI_ENDPOINT empty to fall back to public OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
OPENAI_API_VERSION=2024-02-01

# ── Public OpenAI (fallback) ──────────────────────────────────────────────────
OPENAI_API_KEY=<your-openai-key>
OPENAI_MODEL=gpt-4o-mini

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local dev / demo)
DATABASE_URL=sqlite+aiosqlite:///./scrum_agent.db
# Postgres (production — uncomment and fill in)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/scrum_agent

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000
DEBUG=true

# ── Jira integration (optional) ───────────────────────────────────────────────
JIRA_URL=https://your-org.atlassian.net
JIRA_USERNAME=your@email.com
JIRA_API_TOKEN=<jira-api-token>
JIRA_PROJECT_KEY=KAN

# ── GitHub integration (optional) ─────────────────────────────────────────────
GITHUB_TOKEN=ghp_<your-github-pat>
GITHUB_REPO=org/repo-name
# Gitflow branching strategy
BASE_BRANCH=develop
RELEASE_BRANCH=release/june-2026

# ── Jenkins CI (optional) ──────────────────────────────────────────────────────
JENKINS_URL=http://jenkins.your-org.internal
JENKINS_USER=your-jenkins-user
JENKINS_TOKEN=<jenkins-api-token>
JENKINS_JOB_NAME=healthcare-claims
